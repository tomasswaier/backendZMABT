{
  "openapi": "3.0.0",
  "info": {
    "title": "ZMABT API",
    "version": "1.0.0",
    "description": "API documentation for ZMABT backend"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Local API server"
    }
  ],
  "paths": {
    "/auth/signup": {
      "post": {
        "summary": "Create a new user account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "minLength": 2, "maxLength": 64 },
                  "email": { "type": "string", "format": "email", "maxLength": 254 },
                  "password": { "type": "string", "minLength": 2, "maxLength": 32 },
                  "passwordConfirmation": { "type": "string", "minLength": 2, "maxLength": 32 }
                },
                "required": ["username", "email", "password", "passwordConfirmation"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created successfully" },
          "400": { "description": "Validation error" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "minLength": 2, "maxLength": 64 },
                  "password": { "type": "string", "minLength": 2, "maxLength": 32 }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful, returns access token" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Logout user",
        "responses": {
          "200": { "description": "Logged out successfully" },
          "401": { "description": "User not authenticated" }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/account/profile": {
      "get": {
        "summary": "Get authenticated user's profile",
        "responses": {
          "200": { "description": "Returns user profile" },
          "401": { "description": "User not authenticated" }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/posts/create": {
      "post": {
        "summary": "Create a new post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "postText": { "type": "string", "maxLength": 5000 },
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "longitude": { "type": "number" },
                  "latitude": { "type": "number" }
                },
                "required": ["postText", "rating", "longitude", "latitude"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Post created successfully" },
          "400": { "description": "Validation error" }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/posts/getPageFyp": {
      "get": {
        "summary": "Get FYP posts",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" }, "required": true }
        ],
        "responses": {
          "200": { "description": "Returns paginated posts" }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/posts/getPage": {
      "get": {
        "summary": "Get posts",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" }, "required": true }
        ],
        "responses": {
          "200": { "description": "Returns paginated posts" }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/posts/getPageUser": {
      "get": {
        "summary": "Get posts of authenticated user",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" }, "required": true }
        ],
        "responses": {
          "200": { "description": "Returns user's posts" }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/posts/get": {
      "get": {
        "summary": "Get a single post by ID",
        "parameters": [
          { "name": "postId", "in": "query", "schema": { "type": "integer" }, "required": true }
        ],
        "responses": {
          "200": { "description": "Returns the post" },
          "404": { "description": "Post not found" }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  }
}
